# -----------------------------------------------------------------------------
docs/_build/
site/

# OpenAPI Specs
openapi.json
openapi.yaml
api-spec.json

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints
*.ipynb
.ipynb

# -----------------------------------------------------------------------------
