# -----------------------------------------------------------------------------
*.key
*.pem
*.crt
*.csr
*.p12
*.pfx
credentials.json
secrets.json
*.secret
*.token
.env.local
.env.*.local
.env.production

# Common secret file names
secrets.yaml
secrets.yml
config-secrets.json
api_keys.json
credentials.json
service-account.json

# -----------------------------------------------------------------------------
