# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock

# Package manager logs
.mypy_cache/
.dmypy.json
dmypy.json
.pdm.toml

# PEP 582
__pypackages__/

# Ruff
.ruff_cache/

