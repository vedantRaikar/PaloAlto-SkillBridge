# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*.log
*.cache

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore

# Docker volumes (sensitive)
docker-data/

# -----------------------------------------------------------------------------
